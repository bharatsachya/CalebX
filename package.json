{
  "name": "calebx-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter \"*\" build",
    "bot:start": "bun --cwd packages/telegram-bot start",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "lint": "echo 'No eslint configured yet'",
    "commit:validate": "bun run scripts/commit-validate.ts",
    "push:validate": "bun run scripts/push-validate.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js}": [
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
